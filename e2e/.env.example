# Copie este arquivo para ".env" (dentro de e2e/) e preencha com valores reais.
# NUNCA suba o arquivo ".env" (com valores reais) para o Git.

# Conta admin dedicada de teste (isenta de cota — app/search/quota.py no backend),
# criada uma unica vez via `python -m scripts.create_admin test_e2e_admin` no repo
# privado iaprovalebackend. O script recusa se o nome ja existir e imprime a senha
# gerada UMA vez no stdout — copie imediatamente para E2E_ADMIN_PASSWORD abaixo.
# NUNCA use a conta real "jonas" aqui.
E2E_ADMIN_USERNAME=test_e2e_admin
E2E_ADMIN_PASSWORD=
